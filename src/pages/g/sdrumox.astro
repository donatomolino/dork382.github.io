---
import "@fontsource-variable/inter";

const description =
  "Sdrumox is a retro-styled pixel boss battle where you must beat the boss before its charge reaches 100%.";
---

<!doctype html>
<html lang="it" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#233446" />
    <title>Sdrumox | Donato Molino</title>

    <style>
      :root {
        color-scheme: dark;
        --ink: #26384b;
        --ink-soft: #5e6f7f;
        --paper: #fbf7ea;
        --paper-deep: #e9ddbf;
        --paper-edge: #baaa7d;
        --battle-blue: #cfe4ff;
        --battle-green: #92bc71;
        --battle-earth: #cb9868;
        --accent-red: #c66b5d;
        --accent-gold: #d7b463;
        --accent-blue: #7094c5;
        --shadow: 0 16px 0 #8b7b57, 0 34px 64px rgba(7, 11, 20, 0.28);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
        margin: 0;
      }

      body {
        background:
          radial-gradient(circle at top, rgba(243, 231, 191, 0.18), transparent 28%),
          radial-gradient(circle at bottom right, rgba(122, 162, 218, 0.18), transparent 30%),
          linear-gradient(180deg, #415d7d 0%, #2f4560 48%, #213244 100%);
        color: var(--ink);
        font-family: "Trebuchet MS", "Inter Variable", sans-serif;
      }

      button,
      a {
        font: inherit;
      }

      .shell {
        display: grid;
        place-items: center;
        width: 100vw;
        min-height: 100dvh;
        padding: 0.35rem;
      }

      .screen-frame {
        position: relative;
        display: grid;
        grid-template-rows: minmax(0, 1fr) auto;
        gap: 0.75rem;
        width: min(1180px, calc(100vw - 0.7rem));
        height: min(920px, calc(100dvh - 0.7rem));
        padding: 0.85rem;
        border: 4px solid #223446;
        border-radius: 32px;
        background: linear-gradient(180deg, #fdf9ee, #e7dbbd);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .screen-frame::before {
        content: "";
        position: absolute;
        inset: 10px;
        border: 2px solid rgba(35, 52, 70, 0.16);
        border-radius: 24px;
        pointer-events: none;
      }

      .battle-stage {
        position: relative;
        min-height: 0;
        overflow: hidden;
        border: 4px solid var(--ink);
        border-radius: 28px;
        background:
          linear-gradient(180deg, var(--battle-blue) 0%, #e7f1fb 47%, var(--battle-green) 47%, #7ea95e 69%, var(--battle-earth) 69%, #c28758 100%);
        box-shadow: inset 0 -12px 0 rgba(56, 79, 104, 0.12);
      }

      .battle-stage::before {
        content: "";
        position: absolute;
        top: 18%;
        left: 50%;
        width: 26%;
        aspect-ratio: 1;
        transform: translateX(-50%);
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255, 246, 222, 0.92), rgba(255, 246, 222, 0.2) 58%, transparent 70%);
        opacity: 0.9;
        pointer-events: none;
      }

      .battle-stage::after {
        content: "";
        position: absolute;
        right: 0;
        bottom: 0;
        left: 0;
        height: 18%;
        background:
          radial-gradient(circle at 20% -30%, rgba(255, 255, 255, 0.18), transparent 40%),
          repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.1) 0 30px, rgba(255, 255, 255, 0) 30px 60px);
        opacity: 0.28;
        pointer-events: none;
      }

      .battle-stage.stage-shake {
        animation: stage-shake 180ms steps(2, jump-none);
      }

      #sdrumox-canvas {
        display: block;
        width: 100%;
        height: 100%;
        min-height: 0;
        image-rendering: pixelated;
        image-rendering: crisp-edges;
      }

      .hud-layer {
        position: absolute;
        inset: 0;
        display: grid;
        grid-template-rows: auto 1fr auto;
        gap: 1rem;
        padding: 1rem;
        pointer-events: none;
      }

      .arena-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.9rem;
      }

      .arena-bottom {
        display: flex;
        align-items: flex-end;
        justify-content: flex-end;
      }

      .arena-flags {
        display: grid;
        gap: 0.5rem;
        justify-items: end;
      }

      .status-card,
      .status-chip,
      .bonus-chip,
      .utility-button,
      .dialogue-box,
      .command-box,
      .action-card {
        border: 3px solid var(--ink);
        background: linear-gradient(180deg, var(--paper), var(--paper-deep));
        color: var(--ink);
      }

      .status-card {
        width: min(29rem, 68%);
        border-radius: 24px 12px 24px 12px;
        box-shadow: 0 6px 0 var(--paper-edge);
        padding: 0.75rem 0.9rem;
      }

      .status-card--player {
        width: min(24rem, 54%);
      }

      .status-main {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.55rem;
      }

      .status-main strong {
        display: block;
        font-size: clamp(1rem, 2vw, 1.35rem);
        line-height: 1;
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }

      .level-chip,
      .status-line,
      .charge-row,
      .bonus-chip,
      .status-chip,
      .action-card span,
      .dialogue-line,
      .utility-button {
        font-family: "Consolas", "Courier New", monospace;
      }

      .level-chip {
        font-size: 0.88rem;
        font-weight: 800;
        color: var(--ink-soft);
        text-transform: uppercase;
      }

      .meter-stack {
        display: grid;
        gap: 0.35rem;
      }

      .meter {
        position: relative;
        height: 0.9rem;
        overflow: hidden;
        border: 3px solid var(--ink);
        border-radius: 999px;
        background: #e2d7bc;
      }

      .meter::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(255, 255, 255, 0.22) 50%, transparent 50%);
        background-size: 14px 100%;
        opacity: 0.45;
        pointer-events: none;
      }

      .meter-fill {
        position: absolute;
        inset: 0 auto 0 0;
        width: 100%;
        border-radius: 999px;
        transition: width 120ms linear;
      }

      .meter-fill.player-hp {
        background: linear-gradient(90deg, #628b46, #a3d46f);
      }

      .meter-fill.boss-hp {
        background: linear-gradient(90deg, #ba6453, #df9b77);
      }

      .meter-fill.charge {
        background: linear-gradient(90deg, #7f91ca, #71c0c2);
      }

      .status-line {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.76rem;
        font-weight: 800;
        color: var(--ink-soft);
        text-transform: uppercase;
      }

      .charge-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 0.55rem;
        margin-top: 0.45rem;
        font-size: 0.76rem;
        font-weight: 800;
        color: var(--ink-soft);
        text-transform: uppercase;
      }

      .status-chip,
      .bonus-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2rem;
        border-radius: 14px;
        box-shadow: 0 4px 0 var(--paper-edge);
        padding: 0.38rem 0.7rem;
        font-size: 0.74rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .status-chip.accent {
        border-color: #7e632e;
        background: linear-gradient(180deg, #ffeec4, #efcf7d);
        box-shadow: 0 4px 0 #b38e48;
        color: #6d4e16;
      }

      .stage-message {
        position: absolute;
        bottom: 1rem;
        left: 1rem;
        z-index: 2;
        max-width: min(22rem, calc(100% - 2rem));
        border: 3px solid var(--ink);
        border-radius: 18px 10px 18px 10px;
        background: linear-gradient(180deg, rgba(251, 247, 234, 0.96), rgba(233, 221, 191, 0.96));
        box-shadow: 0 5px 0 var(--paper-edge);
        color: var(--ink);
        padding: 0.6rem 0.75rem;
        font-family: "Consolas", "Courier New", monospace;
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        line-height: 1.35;
        text-transform: uppercase;
      }

      .floaters {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
      }

      .floater {
        position: absolute;
        transform: translate(-50%, -50%);
        font-family: "Consolas", "Courier New", monospace;
        font-size: 1.08rem;
        font-weight: 900;
        text-shadow: 2px 2px 0 rgba(39, 47, 57, 0.25);
        animation: floater-rise 840ms ease-out forwards;
        white-space: nowrap;
      }

      .floater.damage {
        color: #b73636;
      }

      .floater.heal {
        color: #44703f;
      }

      .floater.charge {
        color: #886520;
      }

      .command-deck {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1.06fr) minmax(22rem, 0.94fr);
        gap: 0.75rem;
        min-height: 15.8rem;
      }

      .dialogue-box,
      .command-box {
        border-radius: 24px 12px 24px 12px;
        box-shadow: 0 8px 0 var(--paper-edge);
        min-height: 0;
      }

      .dialogue-box {
        padding: 0.7rem;
      }

      .dialogue-log {
        display: grid;
        align-content: start;
        gap: 0.45rem;
        max-height: 100%;
        overflow: auto;
        padding-right: 0.15rem;
      }

      .dialogue-line {
        border: 2px solid rgba(35, 52, 70, 0.18);
        border-radius: 14px 8px 14px 8px;
        background: rgba(255, 255, 255, 0.48);
        color: var(--ink);
        padding: 0.6rem 0.7rem;
        font-size: 0.84rem;
        line-height: 1.38;
      }

      .dialogue-line:last-child {
        border-color: rgba(112, 148, 197, 0.45);
        background: rgba(222, 233, 250, 0.78);
      }

      .command-box {
        display: grid;
        grid-template-rows: auto auto auto;
        gap: 0.6rem;
        padding: 0.7rem;
      }

      .utility-strip {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.5rem;
      }

      .utility-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.5rem;
        border-radius: 999px;
        box-shadow: 0 4px 0 var(--paper-edge);
        cursor: pointer;
        padding: 0.45rem 0.7rem;
        text-decoration: none;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: transform 120ms ease, box-shadow 120ms ease, filter 120ms ease;
      }

      .utility-button:hover {
        transform: translateY(1px);
        box-shadow: 0 2px 0 var(--paper-edge);
        filter: brightness(0.98);
      }

      .utility-button:active {
        transform: translateY(3px);
        box-shadow: none;
      }

      .action-grid,
      .item-strip {
        display: grid;
        gap: 0.5rem;
      }

      .action-grid--moves {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .item-strip {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .action-card {
        appearance: none;
        width: 100%;
        min-height: 4.4rem;
        border-radius: 18px 10px 18px 10px;
        box-shadow: 0 5px 0 var(--paper-edge);
        cursor: pointer;
        padding: 0.65rem 0.75rem;
        text-align: left;
        transition: transform 120ms ease, box-shadow 120ms ease, filter 120ms ease;
      }

      .action-card:hover:enabled {
        transform: translateY(1px);
        box-shadow: 0 2px 0 var(--paper-edge);
        filter: brightness(0.98);
      }

      .action-card:active:enabled {
        transform: translateY(3px);
        box-shadow: none;
      }

      .action-card:disabled {
        opacity: 0.55;
        cursor: not-allowed;
        box-shadow: 0 4px 0 #c2b79c;
      }

      .action-card strong {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.55rem;
        margin-bottom: 0.35rem;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .action-card strong::after {
        content: "";
        flex: 0 0 0.8rem;
        width: 0.8rem;
        height: 0.8rem;
        border-radius: 999px;
        background: var(--accent-gold);
        box-shadow: 0 0 0 2px rgba(35, 52, 70, 0.18);
      }

      .action-card span {
        display: block;
        color: var(--ink-soft);
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        line-height: 1.2;
        text-transform: uppercase;
      }

      .action-card .count {
        margin-top: 0.45rem;
        color: #7a5f2e;
      }

      .action-card--item {
        min-height: 3.9rem;
      }

      .jumpscare {
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        background: radial-gradient(circle, rgba(255, 110, 110, 0.25), rgba(0, 0, 0, 0.95));
        opacity: 0;
        pointer-events: none;
        transform: scale(1.08);
        transition: opacity 120ms ease, transform 120ms ease;
        z-index: 30;
      }

      .jumpscare.active {
        opacity: 1;
        transform: scale(1);
      }

      .jumpscare-inner {
        display: grid;
        justify-items: center;
        gap: 1rem;
      }

      .jumpscare-face {
        position: relative;
        width: min(62vw, 320px);
        aspect-ratio: 1;
        border: 10px solid #fff1cf;
        background: linear-gradient(180deg, #260909, #5a0d15);
        box-shadow: 0 0 0 12px rgba(255, 123, 139, 0.18);
      }

      .jumpscare-face::before,
      .jumpscare-face::after {
        content: "";
        position: absolute;
        top: 26%;
        width: 24%;
        height: 22%;
        background: #ffe082;
        box-shadow: 0 0 0 10px rgba(255, 224, 130, 0.12);
      }

      .jumpscare-face::before {
        left: 17%;
      }

      .jumpscare-face::after {
        right: 17%;
      }

      .jumpscare-mouth {
        width: 56%;
        height: 18%;
        margin-top: -5rem;
        border: 10px solid #fff1cf;
        background: #0d0202;
      }

      .jumpscare-label {
        color: #fff1cf;
        font-family: "Consolas", "Courier New", monospace;
        font-size: clamp(2rem, 7vw, 4rem);
        font-weight: 900;
        letter-spacing: 0.24em;
        text-shadow: 0 6px 0 rgba(0, 0, 0, 0.55);
        text-transform: uppercase;
      }

      @keyframes floater-rise {
        0% {
          opacity: 0;
          transform: translate(-50%, -20%) scale(0.85);
        }

        18% {
          opacity: 1;
        }

        100% {
          opacity: 0;
          transform: translate(-50%, -150%) scale(1.05);
        }
      }

      @keyframes stage-shake {
        0% {
          transform: translate(0, 0);
        }

        25% {
          transform: translate(-5px, 2px);
        }

        50% {
          transform: translate(4px, -3px);
        }

        75% {
          transform: translate(-3px, 2px);
        }

        100% {
          transform: translate(0, 0);
        }
      }

      @media (max-width: 1120px) {
        .command-deck {
          grid-template-columns: 1fr;
          min-height: 21rem;
        }
      }

      @media (max-width: 820px) {
        .screen-frame {
          padding: 0.6rem;
          border-radius: 24px;
        }

        .hud-layer {
          padding: 0.7rem;
          gap: 0.7rem;
        }

        .arena-top {
          display: grid;
          grid-template-columns: 1fr;
        }

        .arena-bottom {
          justify-content: stretch;
        }

        .arena-flags {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          justify-items: stretch;
        }

        .status-card,
        .status-card--player {
          width: 100%;
        }

        .stage-message {
          max-width: calc(100% - 1.4rem);
          bottom: 0.7rem;
          left: 0.7rem;
        }
      }

      @media (max-width: 620px) {
        .screen-frame {
          width: calc(100vw - 0.35rem);
          height: calc(100dvh - 0.35rem);
          gap: 0.55rem;
          padding: 0.45rem;
        }

        .status-main {
          flex-direction: column;
          align-items: flex-start;
        }

        .charge-row,
        .action-grid--moves,
        .item-strip {
          grid-template-columns: 1fr;
        }

        .utility-strip {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .utility-button {
          min-height: 2.15rem;
          padding: 0.35rem 0.45rem;
          font-size: 0.62rem;
        }

        .action-card {
          min-height: 3.55rem;
          padding: 0.55rem 0.65rem;
        }

        .action-card strong {
          font-size: 0.82rem;
        }

        .action-card span,
        .dialogue-line,
        .stage-message {
          font-size: 0.68rem;
        }
      }
    </style>
  </head>

  <body>
    <main class="shell">
      <section class="screen-frame">
        <section class="battle-stage" id="battle-stage">
          <canvas id="sdrumox-canvas" width="960" height="540"></canvas>
          <div class="floaters" id="floaters" aria-hidden="true"></div>

          <div class="hud-layer">
            <div class="arena-top">
              <section class="status-card status-card--boss">
                <div class="status-main">
                  <strong>Sdrumox</strong>
                  <span class="level-chip" id="boss-phase-text">Sdrumox 0%</span>
                </div>

                <div class="meter-stack">
                  <div class="meter">
                    <div class="meter-fill boss-hp" id="boss-hp-fill"></div>
                  </div>

                  <div class="status-line">
                    <span>HP</span>
                    <span id="boss-hp-text">220 / 220</span>
                  </div>
                </div>

                <div class="charge-row">
                  <span>Carica</span>

                  <div class="meter">
                    <div class="meter-fill charge" id="boss-charge-fill"></div>
                  </div>

                  <span id="boss-charge-text">0%</span>
                </div>
              </section>

              <div class="arena-flags">
                <span class="status-chip accent" id="status-badge">Ingresso Boss</span>
                <span class="status-chip" id="round-text">Round 1</span>
              </div>
            </div>

            <div class="arena-bottom">
              <section class="status-card status-card--player">
                <div class="status-main">
                  <strong>Pixel Don</strong>
                  <span class="bonus-chip" id="bonus-life-text">Bonus Vita x1</span>
                </div>

                <div class="meter-stack">
                  <div class="meter">
                    <div class="meter-fill player-hp" id="player-hp-fill"></div>
                  </div>

                  <div class="status-line">
                    <span>HP</span>
                    <span id="player-hp-text">128 / 128</span>
                  </div>
                </div>
              </section>
            </div>
          </div>

          <div class="stage-message" id="stage-message">
            Sdrumox emerge dal rumore. Fai la prima mossa.
          </div>
        </section>

        <section class="command-deck">
          <section class="dialogue-box">
            <div class="dialogue-log" id="dialogue-log"></div>
          </section>

          <section class="command-box">
            <div class="utility-strip">
              <a class="utility-button" href="/">Home</a>
              <button class="utility-button" id="sound-toggle" type="button">Audio ON</button>
              <button class="utility-button" id="restart-battle" type="button">Reset</button>
            </div>

            <div class="action-grid action-grid--moves">
              <button class="action-card" data-move="succhiapolli" type="button">
                <strong>Succhiapolli</strong>
                <span>Drain</span>
              </button>

              <button class="action-card" data-move="finocchio" type="button">
                <strong>Finocchio</strong>
                <span>Debuff</span>
              </button>

              <button class="action-card" data-move="mystery" type="button">
                <strong>???</strong>
                <span>Chaos</span>
              </button>

              <button class="action-card" data-move="lavica" type="button">
                <strong>La Vica</strong>
                <span>Burn</span>
              </button>
            </div>

            <div class="item-strip">
              <button class="action-card action-card--item" data-item="vitaBonus" type="button">
                <strong>Vita Bonus</strong>
                <span class="count" id="item-vitaBonus-count">x1</span>
              </button>

              <button class="action-card action-card--item" data-item="crtShield" type="button">
                <strong>Schermo CRT</strong>
                <span class="count" id="item-crtShield-count">x2</span>
              </button>

              <button class="action-card action-card--item" data-item="turboPatch" type="button">
                <strong>Turbo Patch</strong>
                <span class="count" id="item-turboPatch-count">x1</span>
              </button>
            </div>
          </section>
        </section>
      </section>
    </main>

    <div class="jumpscare" id="jumpscare" aria-hidden="true">
      <div class="jumpscare-inner">
        <div class="jumpscare-face"></div>
        <div class="jumpscare-mouth"></div>
        <div class="jumpscare-label">???</div>
      </div>
    </div>

    <script>
      import "../../scripts/sdrumox";
    </script>
  </body>
</html>
