---
import { Icon } from "astro-icon/components";
import ThemeSwitcher from "~/components/theme-switcher.astro";
import type { NavItem } from "~/types";

const navItems: Array<NavItem> = [
  { title: "Showcase", url: "#showcase" },
  { title: "Skills", url: "#skills" },
];
---

<header
  id="page-header"
  class="absolute bottom-0 z-20 flex w-full items-center justify-between border-b border-transparent px-8 py-4 text-white"
>
  <span id="CTASocial" class="block text-center text-gray-400 text-xs hidden"
    >Remember to look up to the stars</span
  >
  <div class="flex items-center gap-3 pl-6 hover:!text-default">
    <h1 class="sr-only">Donato Molino</h1>
    <span id="brandName" class="hidden font-bold text-xl">Donato Molino</span>
  </div>
  <div>
    <div class="flex items-center gap-6">
      <nav class="hidden sm:block">
        <ul class="flex items-center gap-6">
          {
            navItems.map(({ title, url }) => (
              <li>
                <a class="text-sm" href={url}>
                  {title}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <ThemeSwitcher />
      <button
        id="open-nav-button"
        type="button"
        class="btn sm:hidden"
        aria-label="Navigation"
      >
        <Icon name="mdi:menu" class="size-8" />
      </button>
    </div>
    <div id="menu-modal" class="modal hidden" aria-hidden="true">
      <div class="fixed inset-0 bg-default px-8 py-4 text-default">
        <div class="space-y-4" role="dialog" aria-modal="true">
          <header class="text-right">
            <button
              id="close-nav-button"
              type="button"
              class="btn"
              aria-label="Close navigation"
            >
              <Icon name="mdi:close" class="size-8" />
            </button>
          </header>
          <div class="flex justify-center">
            <span class="font-bold text-blue-400 text-2xl">Donato Molino</span>
          </div>
          <nav>
            <ul class="flex flex-col">
              {
                navItems.map(({ title, url }) => (
                  <li>
                    <a class="block py-4 text-center text-xl" href={url}>
                      {title}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import MicroModal from "micromodal";
  import invariant from "tiny-invariant";

  const menuModalId = "menu-modal";

  const header = document.querySelector("#page-header") as HTMLElement;
  const brandName = document.querySelector("#brandName") as HTMLElement;
  const CTASocial = document.querySelector("#CTASocial") as HTMLElement;
  const page = document.documentElement;
  const menu = document.querySelector(`#${menuModalId} ul`);
  const openNavButton = document.querySelector("#open-nav-button");
  const closeNavButton = document.querySelector("#close-nav-button");

  invariant(header, "header should not be null");
  invariant(menu, "menu should not be null");
  invariant(openNavButton, "openNavButton should not be null");
  invariant(closeNavButton, "closeNavButton should not be null");

  const openMenu = () => {
    MicroModal.show(menuModalId, { disableScroll: true });
  };

  const closeMenu = () => {
    MicroModal.close(menuModalId);
  };

  openNavButton.addEventListener("click", openMenu);
  closeNavButton.addEventListener("click", closeMenu);

  document.addEventListener("scroll", () => {
    const d = page.clientHeight - page.scrollTop - header.offsetHeight;
    header.classList.toggle("fixed-header", d < 0);
    brandName.classList.toggle("hidden", d > 0);
    CTASocial.classList.toggle("hidden", d < 0);
  });

  menu.addEventListener("click", (event) => {
    if ((event.target as HTMLElement).tagName === "A") {
      closeMenu();
    }
  });

  const initBubbleTextEffect = () => {
    const textElements = Array.from(document.body.querySelectorAll("*")).filter(
      (element) => {
        if (!(element instanceof HTMLElement)) {
          return false;
        }

        const excludedTags = [
          "SCRIPT",
          "STYLE",
          "NOSCRIPT",
          "SVG",
          "CANVAS",
          "CODE",
          "PRE",
          "INPUT",
          "BUTTON",
          "TEXTAREA",
          "SELECT",
        ];

        if (excludedTags.includes(element.tagName)) {
          return false;
        }

        const text = element.textContent?.trim() ?? "";
        return text.length > 0 && element.childElementCount === 0;
      },
    );

    const updateBubble = (element: HTMLElement, event: PointerEvent) => {
      const rect = element.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;
      const dx = x - 50;
      const dy = y - 50;
      const distance = Math.min(Math.sqrt(dx * dx + dy * dy) / 50, 1);
      const strength = Math.max(0, 1 - distance);
      const opacity = Math.max(0, 0.7 - distance * 0.65);

      element.style.setProperty("--bubble-x", `${x}%`);
      element.style.setProperty("--bubble-y", `${y}%`);
      element.style.setProperty("--bubble-strength", `${strength}`);
      element.style.setProperty("--bubble-opacity", `${opacity}`);
    };

    textElements.forEach((element) => {
      element.classList.add("bubble-text");
      element.style.setProperty("--bubble-x", "50%");
      element.style.setProperty("--bubble-y", "50%");
      element.style.setProperty("--bubble-strength", "0");
      element.style.setProperty("--bubble-opacity", "0");

      element.addEventListener("pointermove", (event) => updateBubble(element, event));
      element.addEventListener("pointerleave", () => {
        element.style.setProperty("--bubble-strength", "0");
        element.style.setProperty("--bubble-opacity", "0");
      });
    });
  };

  document.addEventListener("DOMContentLoaded", initBubbleTextEffect);
</script>

<noscript>
  <style>
    #open-nav-button {
      display: none;
    }
  </style>
</noscript>

<style>
  .fixed-header {
    @apply fixed bottom-auto top-0;
    @apply border-default bg-default text-default;
  }
  .modal.is-open {
    @apply block;
  }
</style>
