---
const title = "SimpleNote | Donato Molino";
const description = "Un editor di testo minimale, distraction-free. Scrivi e basta.";
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
      }

      html, body {
        height: 100%;
        margin: 0;
        padding: 0;
      }

      body {
        background: #ffffff;
        color: #1a1a1a;
        font-family: Georgia, "Times New Roman", Times, ui-serif, serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-y: auto;
        overflow-x: hidden;
      }

      #app {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .editor-wrap {
        flex: 1;
        display: flex;
        justify-content: center;
        padding: 2rem 1.5rem 6rem;
      }

      @media (min-width: 640px) {
        .editor-wrap {
          padding: 3rem 2rem 8rem;
        }
      }

      #editor {
        width: 100%;
        max-width: 720px;
        min-height: 100%;
        border: none;
        outline: none;
        background: transparent;
        color: inherit;
        font-family: inherit;
        font-size: clamp(1.05rem, 1rem + 0.3vw, 1.2rem);
        line-height: 1.8;
        caret-color: #1a1a1a;
        white-space: pre-wrap;
        word-wrap: break-word;
      }

      #editor:empty::before {
        content: "Write here\u2026";
        color: #bbb;
        pointer-events: none;
      }

      #editor b, #editor strong {
        font-weight: 700;
      }

      #editor i, #editor em {
        font-style: italic;
      }

      #editor u {
        text-decoration: underline;
      }

      .statusbar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.5rem 1.5rem;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, system-ui, sans-serif;
        font-size: 0.75rem;
        color: #aaa;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-top: 1px solid rgba(0, 0, 0, 0.05);
        user-select: none;
        z-index: 100;
      }

      @media (min-width: 640px) {
        .statusbar {
          padding: 0.6rem 2rem;
        }
      }

      .status-left,
      .status-right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .save-indicator {
        opacity: 0;
        transition: opacity 0.3s ease;
        min-width: 3.5rem;
        text-align: center;
        font-size: 0.7rem;
      }

      .save-indicator.visible {
        opacity: 1;
      }

      .btn-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        padding: 0.3rem 0.55rem;
        border: none;
        border-radius: 0.3rem;
        background: transparent;
        color: #999;
        font-family: inherit;
        font-size: inherit;
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease;
        line-height: 1;
      }

      .btn-icon:hover {
        background: rgba(0, 0, 0, 0.04);
        color: #333;
      }

      .btn-icon.danger:hover {
        background: rgba(220, 38, 38, 0.06);
        color: #dc2626;
      }

      .btn-icon svg {
        width: 0.9rem;
        height: 0.9rem;
        flex-shrink: 0;
      }

      .hidden-sm {
        display: none;
      }

      @media (min-width: 640px) {
        .hidden-sm {
          display: inline;
        }
      }

      .key-hint {
        display: none;
      }

      @media (min-width: 640px) {
        .key-hint {
          display: inline;
          opacity: 0.5;
        }
      }
    </style>
  </head>

  <body>
    <div id="app">
      <div class="editor-wrap">
        <div id="editor" contenteditable="true" spellcheck="false" autofocus></div>
      </div>

      <div class="statusbar">
        <div class="status-left">
          <span id="word-count">0 parole · 0 caratteri</span>
        </div>

        <div class="save-indicator" id="save-indicator" aria-live="polite"></div>

        <div class="status-right">
          <button class="btn-icon" id="btn-download" title="Scarica come .txt" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            <span class="hidden-sm">Scarica</span>
          </button>

          <button class="btn-icon danger" id="btn-clear" title="Cancella tutto" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            </svg>
            <span class="hidden-sm">Pulisci</span>
          </button>
        </div>
      </div>
    </div>

    <script>
      (function () {
        var STORAGE_KEY = "donatomolino:simplenote";
        var editor = document.getElementById("editor");
        var wordCountEl = document.getElementById("word-count");
        var saveIndicator = document.getElementById("save-indicator");

        function canUseStorage() {
          try {
            var x = "__test__";
            localStorage.setItem(x, x);
            localStorage.removeItem(x);
            return true;
          } catch (e) {
            return false;
          }
        }

        var storageAvailable = canUseStorage();

        function getPlainText() {
          return editor.innerText || editor.textContent || "";
        }

        function loadText() {
          if (!storageAvailable) return;
          try {
            var saved = localStorage.getItem(STORAGE_KEY);
            if (saved !== null) {
              editor.innerHTML = saved;
            }
          } catch (e) {}
        }

        function saveText() {
          if (!storageAvailable) return;
          try {
            localStorage.setItem(STORAGE_KEY, editor.innerHTML);
            showSaved();
          } catch (e) {}
        }

        var debounceTimer = null;
        function debouncedSave() {
          if (debounceTimer) clearTimeout(debounceTimer);
          debounceTimer = setTimeout(saveText, 500);
        }

        function updateCounter() {
          var text = getPlainText();
          var chars = text.length;
          var words = text.trim() === "" ? 0 : text.trim().split(/\s+/).length;
          wordCountEl.textContent = words + " parole \u00b7 " + chars + " caratteri";
        }

        var saveIndicatorTimer = null;
        function showSaved() {
          saveIndicator.textContent = "Salvato";
          saveIndicator.classList.add("visible");
          if (saveIndicatorTimer) clearTimeout(saveIndicatorTimer);
          saveIndicatorTimer = setTimeout(function () {
            saveIndicator.classList.remove("visible");
          }, 2000);
        }

        function downloadTxt() {
          var text = getPlainText();
          var blob = new Blob([text], { type: "text/plain;charset=utf-8" });
          var url = URL.createObjectURL(blob);
          var a = document.createElement("a");
          a.href = url;
          a.download = "simplenote.txt";
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        }

        function clearAll() {
          var confirmed = confirm(
            "Sei sicuro di voler cancellare tutto il testo? Questa azione non può essere annullata."
          );
          if (confirmed) {
            editor.innerHTML = "";
            saveText();
            updateCounter();
            editor.focus();
          }
        }

        editor.addEventListener("input", function () {
          debouncedSave();
          updateCounter();
        });

        document.addEventListener("keydown", function (e) {
          var isCmd = e.ctrlKey || e.metaKey;

          if (isCmd && e.key.toLowerCase() === "s") {
            e.preventDefault();
            if (debounceTimer) clearTimeout(debounceTimer);
            saveText();
            return;
          }

          if (isCmd && e.key === "Backspace") {
            e.preventDefault();
            clearAll();
            return;
          }

          if (e.key === "Escape") {
            editor.blur();
            return;
          }
        });

        document.getElementById("btn-download").addEventListener("click", downloadTxt);
        document.getElementById("btn-clear").addEventListener("click", clearAll);

        loadText();
        updateCounter();
        editor.focus();
      })();
    </script>
  </body>
</html>
