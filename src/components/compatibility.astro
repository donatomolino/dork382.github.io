---

<ContentSection title="Skills" id="skills">
  <Fragment slot="lead">
    A cleaner map of the stack I use across <span class="text-primary">product
      UI</span>, <span class="text-primary">backend systems</span>, <span
      class="text-primary">cloud delivery</span>, and <span class="text-primary"
      >hands-on tooling</span
    >.
  </Fragment>
  <div class="grid w-full max-w-6xl gap-8 lg:grid-cols-2 2xl:grid-cols-3">
    <CompatibilityList
      items={frontendSkills}
      title="Frontend"
      description="UI architecture, rendering strategy, state flow, and performance-sensitive delivery."
    />
    <CompatibilityList
      items={backendSkills}
      title="Backend"
      description="Service APIs, language runtime choices, persistence, and systems-facing implementation."
    />
    <CompatibilityList
      items={productAndToolingSkills}
      title="Product & Tools"
      description="Design workflow, CMS and commerce tooling, editor workflow, and interactive build tools."
    />
    <CompatibilityList
      items={cloudAndDevOpsSkills}
      title="Cloud & DevOps"
      description="Runtime infrastructure, containerization, and release automation for shipping reliably."
    />
    <CompatibilityList
      items={architectureSkills}
      title="Architecture"
      description="How systems are shaped for scale, separation of concerns, and long-lived product evolution."
    />
    <CompatibilityList
      items={testingSkills}
      title="Testing"
      description="Fast feedback loops from unit-level validation to browser-level regression coverage."
    />
  </div>
</ContentSection>
