---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import astronautImage from "~/assets/astronaut.png";
import HeroImage from "~/components/hero-image.astro";
import Starfield from "~/components/starfield.astro";
import FloatingCube from "~/components/floating-cube.astro";

const widths = [450, 800];
const sizes = "(min-width: 640px) 42vw, 67vw";
---

<section class="relative h-full bg-black">
  <Starfield />
  <div id="splash-bg-fallback" class="absolute inset-0 hidden opacity-40">
    <HeroImage />
  </div>
  <div class="relative grid h-full place-items-center sm:grid-cols-2">
    <h2
      class="mb-10 flex flex-col items-center gap-4 self-end sm:self-auto sm:justify-self-end"
    >
      <div
        class="gradient-text title-bubble text-center font-extrabold tracking-tighter text-6xl md:text-8xl"
        style="--bubble-x: 50%; --bubble-y: 50%; --bubble-strength: 0;"
      >
        Donato Molino
      </div>
      <div
        class="gradient-text text-center font-extralight tracking-tighter text-2xl"
      >
        Full Stack Developer
      </div>
      <div class="flex items-center justify-center gap-3">
        <a
          href="mailto:donatomolino@europe.com"
          class="btn btn-primary rounded-full border-2 border-secondary p-2 text-secondary hover:bg-secondary hover:!text-white"
          aria-label="Contact me for more information"
        >
          Contact Me
        </a>
        <a
          href="https://www.linkedin.com/in/donatomolino-full-stack/"
          class="inline-flex size-11 items-center justify-center rounded-full border-2 border-secondary p-2 text-secondary hover:bg-secondary hover:!text-white"
          aria-label="Visit my LinkedIn profile"
          target="_blank"
          rel="noreferrer"
        >
          <span class="sr-only">LinkedIn</span>
          <Icon class="size-full" name="fa-brands:linkedin-in" />
        </a>
      </div>
    </h2>
    <div
      id="astronaut"
      class="w-2/3 max-w-3xl self-start sm:w-10/12 sm:self-auto sm:justify-self-start"
    >
      <Image
        class="h-full w-full object-cover"
        src={astronautImage}
        widths={widths}
        sizes={sizes}
        loading="eager"
        alt="A floating astronaut in a space suit"
      />
    </div>
    
    <FloatingCube />
  </div>

  <noscript>
    <style>
      #splash-bg-fallback {
        display: block;
      }
    </style>
  </noscript>

  <script is:inline>
    const gradientTextItems = document.querySelectorAll('.gradient-text');
    const updateBubbleFor = (element, event) => {
      const rect = element.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;
      const dx = x - 50;
      const dy = y - 50;
      const distance = Math.min(Math.sqrt(dx * dx + dy * dy) / 50, 1);
      const strength = Math.max(0, 1 - distance);
      const opacity = Math.max(0, 0.7 - distance * 0.65);

      element.style.setProperty('--bubble-x', `${x}%`);
      element.style.setProperty('--bubble-y', `${y}%`);
      element.style.setProperty('--bubble-strength', `${strength}`);
      element.style.setProperty('--bubble-opacity', `${opacity}`);
    };

    gradientTextItems.forEach((element) => {
      element.style.setProperty('--bubble-x', '50%');
      element.style.setProperty('--bubble-y', '50%');
      element.style.setProperty('--bubble-strength', '0');
      element.style.setProperty('--bubble-opacity', '0');

      element.addEventListener('pointermove', (event) => updateBubbleFor(element, event));
      element.addEventListener('pointerleave', () => {
        element.style.setProperty('--bubble-strength', '0');
        element.style.setProperty('--bubble-opacity', '0');
      });
    });
  </script>

  <style>
    @keyframes float {
      0% {
        transform: translate3d(0, 0, 0);
      }

      100% {
        transform: translate3d(0, 30px, 0);
      }
    }

    #astronaut {
      animation: float linear 2.5s infinite alternate;
    }

    @media (prefers-reduced-motion: reduce) {
      #astronaut {
        @apply animate-none;
      }

      :global(#starfield) {
        @apply hidden;
      }

      #splash-bg-fallback {
        @apply block;
      }
    }
  </style>
</section>
