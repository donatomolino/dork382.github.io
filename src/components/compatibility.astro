---
import CompatibilityList from "~/components/compatibility-list.astro";
import ContentSection from "~/components/content-section.astro";
import type { CompatibilityItem } from "~/types";

const frontendSkills: Array<CompatibilityItem> = [
  {
    title: "TypeScript",
    icon: "mdi:language-typescript",
    url: "https://www.typescriptlang.org/",
  },
  {
    title: "React",
    icon: "frameworks/react",
    url: "https://reactjs.org/",
  },
  {
    title: "Redux",
    icon: "mdi:state-machine",
    url: "https://redux.js.org/",
  },
  {
    title: "Next.js",
    icon: "frameworks/next",
    url: "https://nextjs.org/",
  },
  {
    title: "Astro",
    icon: "frameworks/astro",
    url: "https://astro.build/",
  },
  {
    title: "Tailwind CSS",
    icon: "mdi:tailwind",
    url: "https://tailwindcss.com/",
  },
  {
    title: "Core Web Vitals",
    icon: "mdi:speedometer",
    url: "https://web.dev/articles/vitals",
  },
];

const backendSkills: Array<CompatibilityItem> = [
  {
    title: "Node.js",
    icon: "frameworks/node",
    url: "https://nodejs.org/",
  },
  {
    title: "Python",
    icon: "mdi:language-python",
    url: "https://www.python.org/",
  },
  {
    title: "Rust",
    icon: "mdi:language-rust",
    url: "https://www.rust-lang.org/",
  },
  {
    title: "PostgreSQL",
    icon: "mdi:database",
    url: "https://www.postgresql.org/",
  },
  {
    title: "REST & GraphQL",
    icon: "mdi:api",
    url: "https://graphql.org/",
  },
];

const cloudAndDevOpsSkills: Array<CompatibilityItem> = [
  {
    title: "AWS",
    icon: "fa-brands:aws",
    url: "https://aws.amazon.com/",
  },
  {
    title: "GCP",
    icon: "mdi:google-cloud",
    url: "https://cloud.google.com/",
  },
  {
    title: "Docker",
    icon: "fa-brands:docker",
    url: "https://www.docker.com/",
  },
  {
    title: "CI/CD with GitHub Actions",
    icon: "fa-brands:github",
    url: "https://github.com/features/actions",
  },
];

const architectureSkills: Array<CompatibilityItem> = [
  {
    title: "System Design",
    icon: "mdi:sitemap",
    url: "https://martinfowler.com/architecture/",
  },
  {
    title: "Multi-tenant Architecture",
    icon: "mdi:domain",
    url: "https://learn.microsoft.com/en-us/azure/architecture/guide/multitenant/overview",
  },
  {
    title: "Microservices",
    icon: "mdi:graph-outline",
    url: "https://microservices.io/",
  },
];

const testingSkills: Array<CompatibilityItem> = [
  {
    title: "Jest",
    icon: "mdi:test-tube",
    url: "https://jestjs.io/",
  },
  {
    title: "Cypress",
    icon: "mdi:test-tube-empty",
    url: "https://www.cypress.io/",
  },
];

const productAndToolingSkills: Array<CompatibilityItem> = [
  {
    title: "Figma",
    icon: "fa-brands:figma",
    url: "https://www.figma.com/",
  },
  {
    title: "Cursor",
    icon: "mdi:cursor-default-click-outline",
    url: "https://www.cursor.com/",
  },
  {
    title: "Strapi",
    icon: "mdi:file-document-outline",
    url: "https://strapi.io/",
  },
  {
    title: "Salesforce Commerce Cloud",
    icon: "fa-brands:salesforce",
    url: "https://www.salesforce.com/commerce/",
  },
  {
    title: "Unity",
    icon: "platforms/unity",
    url: "https://unity.com/",
  },
