---
import "@fontsource-variable/inter";
import Footer from "~/components/footer.astro";
import Doodles from "~/components/doodles.astro";
import "~/styles/index.css";
import { ClientRouter } from "astro:transitions";

const { generator, site } = Astro;
const description = "Junk feed — pensieri, link e roba varia dal mio canale Telegram";
---

<!doctype html>
<html lang="it" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={generator} />

    <title>Junk Feed | Donato Molino</title>
    <meta name="description" content={description} />
    <ClientRouter />

    <meta property="og:title" content="Junk Feed | Donato Molino" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL("/junkfeed", site).toString()} />

    <script is:inline>
      const themeSaved = localStorage.getItem("theme");
      if (themeSaved) {
        document.documentElement.dataset.theme = themeSaved;
      } else {
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        document.documentElement.dataset.theme = prefersDark ? "dark" : "light";
      }
      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", (event) => {
          if (!localStorage.getItem("theme")) {
            document.documentElement.dataset.theme = event.matches
              ? "dark"
              : "light";
          }
        });
    </script>
  </head>
  <body
    class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white"
  >
    <div class="fixed inset-0 z-0">
      <Doodles />
    </div>

    <div class="fixed inset-0 -z-10 opacity-30">
      <div class="absolute inset-0 bg-radial from-indigo-900/40 via-transparent to-transparent"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 py-12 sm:px-8 sm:py-24">
      <a
        href="/"
        class="btn mb-16 inline-flex items-center gap-2 text-offset text-sm transition-colors hover:text-secondary"
      >
        <svg class="size-4 rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
        Back Home
      </a>

      <h1
        class="gradient-text mb-4 text-center font-extrabold tracking-tighter text-5xl sm:text-7xl"
      >
        Junk Feed
      </h1>
      <p class="mb-16 text-center text-offset text-lg">
        Pensieri, link e roba varia da{" "}
        <a
          href="https://t.me/donniejunkfeed"
          target="_blank"
          rel="noreferrer"
          class="text-secondary underline underline-offset-2 hover:text-indigo-300"
        >
          @donniejunkfeed
        </a>
      </p>

      <div id="junkfeed-posts" class="min-h-[500px]">
        <div id="junkfeed-loading" class="flex flex-col items-center justify-center gap-4 py-20 text-offset">
          <svg class="size-8 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
          </svg>
          <p class="text-lg">Recuperando gli ultimi junk...</p>
        </div>
      </div>
    </div>

    <Footer />
  </body>
</html>

<script>
  interface Post {
    text?: string;
    date: string;
    link: string;
  }

  const API_URL = "https://junk-api.dork3802.workers.dev/posts";

  function formatDate(raw: string): string {
    const d = new Date(raw);
    if (isNaN(d.getTime())) return raw;
    return d.toLocaleDateString("it-IT", {
      year: "numeric",
      month: "long",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
      timeZone: "Europe/Rome",
    });
  }

  function linkify(text: string): string {
    return text.replace(
      /(https?:\/\/[^\s<]+)/g,
      '<a href="$1" target="_blank" rel="noopener noreferrer" class="text-secondary underline underline-offset-2 hover:text-indigo-300">$1</a>',
    );
  }

  function renderPosts(posts: Post[]) {
    const container = document.getElementById("junkfeed-posts")!;

    if (posts.length === 0) {
      container.innerHTML = `
        <div class="flex flex-col items-center justify-center gap-3 py-20 text-offset">
          <svg class="size-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
          </svg>
          <p class="text-lg">Nessun post disponibile.</p>
          <p class="text-sm">Torna più tardi o segui <a href="https://t.me/donniejunkfeed" target="_blank" rel="noreferrer" class="text-secondary underline">@donniejunkfeed</a> su Telegram.</p>
        </div>`;
      return;
    }

    container.innerHTML = `
      <div class="space-y-8">
        ${posts
          .map(
            (post) => `
          <article class="rounded-2xl border border-default bg-offset/50 p-6 shadow-lg transition-shadow hover:shadow-xl sm:p-8">
            <div class="mb-4 flex items-center gap-3">
              <div class="flex size-10 items-center justify-center rounded-full bg-gradient-to-br from-indigo-500 via-fuchsia-500 to-pink-500 font-bold text-white text-xs">JF</div>
              <div>
                <span class="font-semibold text-sm">donniejunkfeed</span>
                <a href="${post.link}" target="_blank" rel="noopener noreferrer" class="ml-2 text-offset text-xs transition-colors hover:text-secondary inline-flex items-center gap-1">${formatDate(post.date)}<svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg></a>
              </div>
            </div>
            ${post.text ? `<div class="prose prose-invert max-w-none"><p class="whitespace-pre-wrap text-default leading-relaxed">${linkify(post.text.replace(/\n/g, "<br>"))}</p></div>` : ""}
            <dymol-reactions target-id="junk_${post.link.split('/').pop()}"></dymol-reactions>
          </article>`
          )
          .join("")}
      </div>`;
  }

  fetch(API_URL)
    .then((res) => {
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      return res.json();
    })
    .then((data: Post[]) => renderPosts(data))
    .catch((err) => {
      console.error("Junkfeed fetch failed:", err);
      const container = document.getElementById("junkfeed-posts")!;
      container.innerHTML = `
        <div class="flex flex-col items-center justify-center gap-3 py-20 text-offset">
          <svg class="size-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 8v4M12 16h.01" />
          </svg>
          <p class="text-lg">Errore nel caricamento.</p>
          <p class="text-sm">Riprova più tardi o visita <a href="https://t.me/donniejunkfeed" target="_blank" rel="noreferrer" class="text-secondary underline">@donniejunkfeed</a> su Telegram.</p>
        </div>`;
    });

  // Dymol Reaction API Web Component
  class DymolReactions extends HTMLElement {
    targetId: string;
    apiKey: string;
    baseUrl: string;
    userId: string;

    constructor() {
      super();
      this.targetId = this.getAttribute('target-id') || 'unknown';
      this.apiKey = "3ZZY8mtaXf6mpM8PNYXWmNg1"; // Dymol public test key
      this.baseUrl = "https://dymol-backend.dork3802.workers.dev";
      
      this.userId = localStorage.getItem('dymol_user_id') || '';
      if (!this.userId) {
        this.userId = 'usr_' + Math.random().toString(36).substring(2, 11);
        localStorage.setItem('dymol_user_id', this.userId);
      }
    }

    async connectedCallback() {
      this.renderLoading();
      await this.fetchReactions();
    }

    async fetchReactions() {
      try {
        const res = await fetch(`${this.baseUrl}/v1/reactions/${this.targetId}`, {
          headers: { 'Authorization': `Bearer ${this.apiKey}` }
        });
        const json = await res.json();
        if (json.success) {
          // Let's also keep track of what the user voted for if we can, but since our API
          // doesn't return the user's specific vote, we'll store their local votes in localStorage
          this.render(json.data.distribution || {});
        } else {
          this.render({});
        }
      } catch (e) {
        this.render({});
      }
    }

    async react(type: string) {
      const btns = this.querySelectorAll('.reaction-btn');
      btns.forEach(b => b.classList.add('opacity-50', 'pointer-events-none'));
      
      try {
        // Save the local vote state
        const storedVotes = JSON.parse(localStorage.getItem('dymol_votes') || '{}');
        storedVotes[this.targetId] = type;
        localStorage.setItem('dymol_votes', JSON.stringify(storedVotes));

        await fetch(`${this.baseUrl}/v1/react`, {
          method: 'POST',
          headers: { 
            'Authorization': `Bearer ${this.apiKey}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            target_id: this.targetId,
            type: type,
            user_id: this.userId
          })
        });
        await this.fetchReactions();
      } catch(e) {
        console.error(e);
        btns.forEach(b => b.classList.remove('opacity-50', 'pointer-events-none'));
      }
    }

    renderLoading() {
      this.innerHTML = `<div class="flex gap-3 mt-5 pt-4 border-t border-offset/10"><div class="h-9 w-20 bg-offset/20 rounded-full animate-pulse"></div><div class="h-9 w-20 bg-offset/20 rounded-full animate-pulse"></div></div>`;
    }

    render(distribution: Record<string, number>) {
      const types = ['like', 'dislike'];
      
      const storedVotes = JSON.parse(localStorage.getItem('dymol_votes') || '{}');
      const userVote = storedVotes[this.targetId]; // Check if user voted for this target

      const icons = {
        like: {
          outline: `<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>`,
          filled: `<svg class="size-5" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>`
        },
        dislike: {
          outline: `<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"></path></svg>`,
          filled: `<svg class="size-5" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"></path></svg>`
        }
      };
      
      const html = types.map(t => {
        const count = distribution[t] || 0;
        const isActive = userVote === t;
        
        const activeClasses = isActive 
          ? (t === 'like' ? 'bg-green-500/20 text-green-400 border-green-500/50 ring-1 ring-green-500/50' : 'bg-red-500/20 text-red-400 border-red-500/50 ring-1 ring-red-500/50')
          : 'bg-offset/5 text-offset border-offset/10 hover:bg-secondary/10 hover:text-secondary hover:border-secondary/30';

        const iconHtml = isActive ? icons[t as keyof typeof icons].filled : icons[t as keyof typeof icons].outline;

        return `<button data-type="${t}" class="reaction-btn flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300 text-sm font-semibold border hover:scale-105 active:scale-95 ${activeClasses}">
          ${iconHtml}
          ${count > 0 ? `<span>${count}</span>` : ''}
        </button>`;
      }).join('');

      this.innerHTML = `<div class="flex gap-3 mt-5 pt-4 border-t border-offset/10">${html}</div>`;

      this.querySelectorAll('.reaction-btn').forEach(btn => {
        btn.addEventListener('click', () => this.react(btn.getAttribute('data-type')!));
      });
    }
  }

  if (!customElements.get('dymol-reactions')) {
    customElements.define('dymol-reactions', DymolReactions);
  }
</script>