---
import "@fontsource-variable/inter";

const description =
  "Flowlight is an interactive liquid-and-gas playground that reacts to touch and mouse with shifting neon color.";
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#04070d" />
    <title>Flowlight | Donato Molino</title>

    <style>
      :root {
        color-scheme: dark;
        --bg-start: #020409;
        --bg-end: #08111a;
        --panel: rgba(4, 7, 13, 0.42);
        --panel-strong: rgba(8, 14, 24, 0.72);
        --panel-border: rgba(255, 255, 255, 0.14);
        --text: rgba(255, 255, 255, 0.94);
        --muted: rgba(233, 241, 255, 0.68);
        --shadow: 0 18px 80px rgba(0, 0, 0, 0.38);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background:
          radial-gradient(circle at 18% 22%, rgba(132, 255, 168, 0.13), transparent 32%),
          radial-gradient(circle at 82% 16%, rgba(255, 84, 184, 0.12), transparent 26%),
          radial-gradient(circle at 58% 78%, rgba(76, 174, 255, 0.11), transparent 28%),
          linear-gradient(155deg, var(--bg-start) 0%, var(--bg-end) 58%, #030407 100%);
        color: var(--text);
        font-family: "Inter Variable", sans-serif;
        touch-action: none;
      }

      body {
        position: relative;
      }

      .experience {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
        isolation: isolate;
      }

      #flowlight-canvas {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        cursor: crosshair;
      }

      .aurora {
        position: fixed;
        inset: -18%;
        pointer-events: none;
        background:
          conic-gradient(
            from 240deg at 50% 50%,
            rgba(104, 255, 168, 0.3),
            rgba(71, 224, 255, 0.08),
            rgba(255, 95, 170, 0.24),
            rgba(255, 199, 54, 0.12),
            rgba(104, 255, 168, 0.3)
          );
        filter: blur(120px) saturate(145%);
        mix-blend-mode: screen;
        opacity: 0.18;
        animation: drift 24s ease-in-out infinite alternate;
      }

      .grain {
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.08;
        mix-blend-mode: soft-light;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
        background-size: 3px 3px, 4px 4px;
      }

      .vignette {
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          radial-gradient(circle at center, transparent 44%, rgba(0, 0, 0, 0.48) 100%),
          linear-gradient(180deg, rgba(2, 4, 9, 0.18), transparent 22%, transparent 78%, rgba(2, 4, 9, 0.42));
      }

      .topbar,
      .copy,
      .note,
      .actions {
        position: fixed;
        z-index: 2;
      }

      .topbar {
        top: clamp(1rem, 2vw, 1.5rem);
        left: clamp(1rem, 2vw, 1.5rem);
        right: clamp(1rem, 2vw, 1.5rem);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand,
      .route,
      .reset-button,
      .hint-chip {
        border: 1px solid var(--panel-border);
        background: var(--panel);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        box-shadow: var(--shadow);
      }

      .brand,
      .route {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        min-height: 2.75rem;
        border-radius: 999px;
        padding: 0.7rem 1rem;
        color: var(--text);
        text-decoration: none;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-size: 0.74rem;
        font-weight: 700;
      }

      .brand::before {
        content: "";
        width: 0.65rem;
        height: 0.65rem;
        border-radius: 999px;
        background: linear-gradient(135deg, #78ffb9, #ff5fb3);
        box-shadow: 0 0 22px rgba(120, 255, 185, 0.8);
      }

      .copy {
        left: clamp(1rem, 4vw, 3rem);
        bottom: clamp(1.5rem, 4vw, 3rem);
        width: min(38rem, calc(100vw - 2rem));
      }

      .eyebrow {
        display: inline-flex;
        margin-bottom: 1rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        padding: 0.5rem 0.8rem;
        color: rgba(255, 255, 255, 0.74);
        letter-spacing: 0.22em;
        text-transform: uppercase;
        font-size: 0.7rem;
        font-weight: 700;
      }

      h1 {
        margin: 0;
        font-size: clamp(4rem, 11vw, 9rem);
        line-height: 0.88;
        letter-spacing: -0.08em;
        text-transform: uppercase;
        font-weight: 900;
        text-wrap: balance;
        text-shadow:
          0 3px 0 rgba(0, 0, 0, 0.34),
          0 0 34px rgba(255, 255, 255, 0.15),
          0 0 60px rgba(87, 255, 180, 0.09);
      }

      .lede {
        max-width: 32rem;
        margin: 1rem 0 0;
        color: var(--muted);
        font-size: clamp(1rem, 1vw + 0.85rem, 1.25rem);
        line-height: 1.55;
        text-wrap: pretty;
      }

      .note {
        top: max(5.5rem, 13vh);
        right: clamp(1rem, 2vw, 1.5rem);
        width: min(18rem, calc(100vw - 2rem));
        padding: 1rem 1.1rem;
        border-radius: 1.25rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: linear-gradient(180deg, rgba(10, 16, 27, 0.7), rgba(5, 9, 16, 0.42));
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: var(--shadow);
      }

      .note strong {
        display: block;
        margin-bottom: 0.45rem;
        font-size: 0.92rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .note p {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.5;
      }

      .actions {
        right: clamp(1rem, 2vw, 1.5rem);
        bottom: clamp(1rem, 2vw, 1.5rem);
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .hint-chip {
        border-radius: 999px;
        padding: 0.75rem 0.95rem;
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.82rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .reset-button {
        appearance: none;
        border-radius: 999px;
        padding: 0.82rem 1.15rem;
        color: var(--text);
        font: inherit;
        font-size: 0.92rem;
        font-weight: 700;
        cursor: pointer;
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          background-color 180ms ease;
      }

      .reset-button:hover {
        transform: translateY(-1px);
        border-color: rgba(255, 255, 255, 0.25);
        background: rgba(12, 18, 30, 0.68);
      }

      .reset-button:focus-visible,
      .brand:focus-visible {
        outline: 2px solid rgba(120, 255, 185, 0.8);
        outline-offset: 3px;
      }

      @keyframes drift {
        from {
          transform: translate3d(-2%, -1%, 0) rotate(-5deg) scale(1.02);
        }

        to {
          transform: translate3d(2%, 1.5%, 0) rotate(4deg) scale(1.08);
        }
      }

      @media (max-width: 900px) {
        .topbar {
          flex-wrap: wrap;
          align-items: flex-start;
        }

        .note {
          top: auto;
          bottom: 6.4rem;
          left: 1rem;
          right: 1rem;
          width: auto;
        }

        .actions {
          left: 1rem;
          right: auto;
        }

        .copy {
          bottom: 10.8rem;
        }
      }

      @media (max-width: 640px) {
        h1 {
          font-size: clamp(3rem, 19vw, 4.6rem);
        }

        .copy {
          width: calc(100vw - 2rem);
        }

        .lede {
          font-size: 0.98rem;
        }

        .hint-chip {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <main class="experience">
      <canvas id="flowlight-canvas" aria-hidden="true"></canvas>
      <div class="aurora"></div>
      <div class="grain"></div>
      <div class="vignette"></div>

      <header class="topbar">
        <a class="brand" href="/">Back Home</a>
        <span class="route">/e/flowlight</span>
      </header>

      <section class="copy">
        <span class="eyebrow">Experimental Fluid Study</span>
        <h1>Flowlight</h1>
        <p class="lede">
          Touch or drag to bend a luminous gas field. Every gesture injects new
          momentum, shifts the hue, and leaves behind soft liquid trails.
        </p>
      </section>

      <aside class="note">
        <strong>Mouse + Touch Reactive</strong>
        <p>
          Slow movements create velvet smoke. Fast swipes bloom into brighter,
          denser liquid color.
        </p>
      </aside>

      <div class="actions">
        <span class="hint-chip">Move to paint the field</span>
        <button id="reset-field" class="reset-button" type="button">
          Reset Field
        </button>
      </div>
    </main>

    <script>
      import "../../scripts/flowlight";
    </script>
  </body>
</html>