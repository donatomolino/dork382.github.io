---
// Floating 3D Object that evades the mouse and morphs into different 3D shapes
---
<div class="cube-container absolute bottom-32 left-1/2 -translate-x-1/2 z-10 w-24 h-24 sm:bottom-48">
  <div id="cube-wrapper" class="w-full h-full will-change-transform">
    <div id="interactive-cube" class="cube" data-shape="cube">
      <div class="face f1"></div>
      <div class="face f2"></div>
      <div class="face f3"></div>
      <div class="face f4"></div>
      <div class="face f5"></div>
      <div class="face f6"></div>
    </div>
  </div>
</div>

<script>
  let isCubePhysicsRunning = false;
  let shapeIndex = 0;
  // Shapes mapped to their true 3D equivalents
  const shapes = ['cube', 'sphere', 'pyramid', 'prism', 'ring'];

  function initPhysicsCube() {
    const wrapper = document.getElementById('cube-wrapper');
    const cube = document.getElementById('interactive-cube');
    if (!wrapper || !cube || isCubePhysicsRunning) return;
    
    isCubePhysicsRunning = true;

    let x = 0, y = 0, vx = 0, vy = 0;
    let mouseX = -1000, mouseY = -1000;
    let lastInteractionTime = 0;

    document.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

    function tick() {
      if (!document.getElementById('cube-wrapper')) { isCubePhysicsRunning = false; return; }

      const rect = wrapper.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;

      const dx = centerX - mouseX;
      const dy = centerY - mouseY;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const threshold = 250;

      if (dist < threshold && (Date.now() - lastInteractionTime) > 600) {
        // Apply repulsive force
        const force = (threshold - dist) / threshold;
        vx += (dx / dist) * force * 15; 
        vy += (dy / dist) * force * 15;
        
        // Cycle the 3D shape
        shapeIndex = (shapeIndex + 1) % shapes.length;
        cube.setAttribute('data-shape', shapes[shapeIndex]);
        lastInteractionTime = Date.now();
      }

      // Physics integration
      vx *= 0.94; // Friction
      vy *= 0.94;
      x += vx;
      y += vy;
      wrapper.style.transform = `translate(${x}px, ${y}px)`;

      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  
  initPhysicsCube();
  document.addEventListener('astro:page-load', () => { isCubePhysicsRunning = false; initPhysicsCube(); });
</script>

<style>
  .cube-container { perspective: 1000px; pointer-events: none; }
  #cube-wrapper { pointer-events: auto; }
  
  .cube { 
    width: 100%; height: 100%; position: relative; 
    transform-style: preserve-3d;
    animation: float-rotate 10s infinite linear;
  }
  
  .face { 
    position: absolute; width: 100%; height: 100%; 
    background: rgba(99, 102, 241, 0.4); 
    border: 2px solid rgba(217, 70, 239, 0.8);
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-origin: center center;
    box-shadow: 0 0 15px rgba(236, 72, 153, 0.3) inset;
  }

  /* 1. CUBE (Base 3D) */
  .cube[data-shape="cube"] .f1 { transform: rotateY(  0deg) translateZ(48px); }
  .cube[data-shape="cube"] .f2 { transform: rotateY( 90deg) translateZ(48px); }
  .cube[data-shape="cube"] .f3 { transform: rotateY(180deg) translateZ(48px); }
  .cube[data-shape="cube"] .f4 { transform: rotateY(-90deg) translateZ(48px); }
  .cube[data-shape="cube"] .f5 { transform: rotateX( 90deg) translateZ(48px); }
  .cube[data-shape="cube"] .f6 { transform: rotateX(-90deg) translateZ(48px); }

  /* 2. SPHERE (Atom - Intersecting Rings) */
  .cube[data-shape="sphere"] .face { border-radius: 50%; background: rgba(34, 211, 238, 0.1); border-width: 4px; box-shadow: 0 0 30px rgba(34, 211, 238, 0.5) inset; }
  .cube[data-shape="sphere"] .f1 { transform: rotateY(0deg) rotateX(45deg); }
  .cube[data-shape="sphere"] .f2 { transform: rotateY(60deg) rotateX(45deg); }
  .cube[data-shape="sphere"] .f3 { transform: rotateY(120deg) rotateX(45deg); }
  .cube[data-shape="sphere"] .f4 { transform: rotateY(90deg) rotateZ(45deg); }
  .cube[data-shape="sphere"] .f5 { transform: rotateY(150deg) rotateZ(45deg); }
  .cube[data-shape="sphere"] .f6 { transform: rotateY(30deg) rotateZ(45deg); }

  /* 3. PYRAMID (3D Tetrahedron / Square Pyramid) */
  .cube[data-shape="pyramid"] .f1, .cube[data-shape="pyramid"] .f2, .cube[data-shape="pyramid"] .f3, .cube[data-shape="pyramid"] .f4 { transform-origin: bottom center; clip-path: polygon(50% 0%, 0% 100%, 100% 100%); }
  .cube[data-shape="pyramid"] .f1 { transform: rotateY(  0deg) translateZ(48px) rotateX(30deg); }
  .cube[data-shape="pyramid"] .f2 { transform: rotateY( 90deg) translateZ(48px) rotateX(30deg); }
  .cube[data-shape="pyramid"] .f3 { transform: rotateY(180deg) translateZ(48px) rotateX(30deg); }
  .cube[data-shape="pyramid"] .f4 { transform: rotateY(-90deg) translateZ(48px) rotateX(30deg); }
  .cube[data-shape="pyramid"] .f5 { transform: scale(0); } /* Hide top face */
  .cube[data-shape="pyramid"] .f6 { transform-origin: center center; transform: rotateX(-90deg) translateZ(48px); } /* Square base */

  /* 4. PRISM (3D Hexagonal Tube) */
  /* translateZ = 48 / tan(30deg) = ~83px */
  .cube[data-shape="prism"] .face { width: 56px; left: 20px; background: rgba(234, 179, 8, 0.4); border-color: rgba(234, 179, 8, 0.9); }
  .cube[data-shape="prism"] .f1 { transform: rotateY(  0deg) translateZ(48px); }
  .cube[data-shape="prism"] .f2 { transform: rotateY( 60deg) translateZ(48px); }
  .cube[data-shape="prism"] .f3 { transform: rotateY(120deg) translateZ(48px); }
  .cube[data-shape="prism"] .f4 { transform: rotateY(180deg) translateZ(48px); }
  .cube[data-shape="prism"] .f5 { transform: rotateY(240deg) translateZ(48px); }
  .cube[data-shape="prism"] .f6 { transform: rotateY(300deg) translateZ(48px); }

  /* 5. RING (Torus-like 3D band) */
  .cube[data-shape="ring"] .face { height: 30px; top: 33px; border-radius: 10px; background: rgba(236, 72, 153, 0.4); border-color: rgba(236, 72, 153, 0.9); }
  .cube[data-shape="ring"] .f1 { transform: rotateX(90deg) rotateY(  0deg) translateZ(60px); }
  .cube[data-shape="ring"] .f2 { transform: rotateX(90deg) rotateY( 60deg) translateZ(60px); }
  .cube[data-shape="ring"] .f3 { transform: rotateX(90deg) rotateY(120deg) translateZ(60px); }
  .cube[data-shape="ring"] .f4 { transform: rotateX(90deg) rotateY(180deg) translateZ(60px); }
  .cube[data-shape="ring"] .f5 { transform: rotateX(90deg) rotateY(240deg) translateZ(60px); }
  .cube[data-shape="ring"] .f6 { transform: rotateX(90deg) rotateY(300deg) translateZ(60px); }

  /* Global Rotation to show off 3D depth */
  @keyframes float-rotate {
    0%   { transform: rotateX(-20deg) rotateY(0deg) rotateZ(10deg); }
    100% { transform: rotateX(340deg) rotateY(360deg) rotateZ(370deg); }
  }
</style>